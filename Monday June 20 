      "source": [
        "from research- Cohen's d, meansures how many standard deviations apart the two group means are- a way to express 'how big is this difference' independent of your sampel size"
      ],
      "metadata": {
        "id": "ncMfW_76pM8V"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "def cohens_d(group1, group2):\n",
        "  n1, n2=len(group1), len(group2)\n",
        "  var1, var2= group1.var(ddof=1), group2.var(ddof=1)\n",
        "  pooled_std=np.sqrt(((n1-1)*var1+(n2-1) *var2)/ (n1+n2-2))\n",
        "  d=(group1.mean()-group2.mean())/pooled_std\n",
        "  return d"
      ],
      "metadata": {
        "id": "omhhBKZPp0Cv"
      },
      "execution_count": 98,
      "outputs": []
    },
