        "'2003' : (pre_2003['Dividend Yield'], post_2003['Dividend Yield']),\n",
        "}\n",
        "for label, (pre, post) in results.items():\n",
        "  d=cohens_d(pre, post)\n",
        "  print(f\"{label}: Cohen's d={d:.3f}\")\n"
      ],
